{
  "manifest_version": 3,
  "name": "Flowboard Bridge",
  "version": "0.0.5",
  "description": "Local bridge that proxies Flowboard agent requests to authenticated labs.google sessions.",
  "permissions": ["storage", "alarms", "tabs", "webRequest", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "https://aisandbox-pa.googleapis.com/*",
    "https://labs.google/*",
    "https://chatgpt.com/*",
    "https://files.oaiusercontent.com/*",
    "http://127.0.0.1:8101/*",
    "http://localhost:8101/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Flowboard Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/fx/tools/flow*",
        "https://labs.google/fx/*/tools/flow*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content_chatgpt.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://labs.google/*"]
    },
    {
      "resources": ["injected_chatgpt.js", "sha3.js"],
      "matches": ["https://chatgpt.com/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "flowboard_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
